let state = (() => {
  try { return JSON.parse(localStorage.getItem('hyrox_v2') || '{}'); } catch(e) { return {}; }
})();
if (!state.days) state.days = {};
if (!state.metrics) state.metrics = {};
if (!state.checks) state.checks = {};
if (!state.week) state.week = 1;

function save() {
  try { localStorage.setItem('hyrox_v2', JSON.stringify(state)); } catch(e) {}
}

function showSection(id, el, mobile) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.getElementById('section-' + id).classList.add('active');
  const isNav = mobile;
  if (isNav) {
    document.querySelectorAll('.bnav-btn').forEach(b => b.classList.remove('active'));
  } else {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  }
  el.classList.add('active');
  if (id === 'plan') renderPlan();
  if (id === 'progress') renderProgress();
  if (id === 'prep') renderChecklist();
  if (id === 'overview') refreshOverview();
}

function goToPlan(w) {
  state.week = w; save();
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.getElementById('section-plan').classList.add('active');
  document.querySelectorAll('.tab').forEach((t,i) => t.classList.toggle('active', i===1));
  document.querySelectorAll('.bnav-btn').forEach((b,i) => b.classList.toggle('active', i===1));
  renderPlan();
}

function renderPlan() {
  const ws = document.getElementById('week-selector');
  const wl = document.getElementById('current-week-label');
  const phl = document.getElementById('week-phase-label');
  const dg = document.getElementById('day-grid');

  wl.textContent = state.week;
  phl.textContent = state.week <= 4 ? 'Phase 1 — Foundation' : state.week <= 8 ? 'Phase 2 — Build' : 'Phase 3 — Race Ready';

  ws.innerHTML = '';
  for (let w = 1; w <= 12; w++) {
    const btn = document.createElement('button');
    btn.className = 'week-btn' + (w === state.week ? ' active' : '') + (isWeekDone(w) ? ' completed' : '');
    btn.textContent = 'W' + w;
    btn.onclick = () => { state.week = w; save(); renderPlan(); };
    ws.appendChild(btn);
  }

  dg.innerHTML = '';
  const wk = WORKOUTS[state.week];
  ['mon','tue','wed','thu','fri'].forEach(day => {
    const w = wk[day]; if (!w) return;
    const key = state.week + '-' + day;
    const done = !!state.days[key];
    const d = DAY_META[day];
    const card = document.createElement('div');
    card.className = 'day-card';
    card.innerHTML = `
      <div class="day-header" onclick="toggleBody('${key}')">
        <div class="day-left">
          <div class="day-dot ${d.dot}"></div>
          <div>
            <div class="day-name">${d.name}</div>
            <div class="day-type">${w.type}</div>
          </div>
        </div>
        <div class="day-right">
          <span class="day-duration">${w.dur}</span>
          <button class="complete-btn ${done?'done':''}" onclick="toggleDone(event,'${key}')" title="Mark complete">✓</button>
        </div>
      </div>
      <div class="day-body" id="b-${key}">
        ${w.blocks.map(b=>`
          <div class="workout-block">
            <div class="workout-label">${b.l}</div>
            <ul class="exercise-list">${b.i.map(x=>`<li>${x}</li>`).join('')}</ul>
          </div>`).join('')}
        ${w.note ? `<div class="note-block">💡 ${w.note}</div>` : ''}
      </div>`;
    dg.appendChild(card);
  });
}

function toggleBody(key) {
  const el = document.getElementById('b-' + key);
  if (el) el.classList.toggle('open');
}

function toggleDone(e, key) {
  e.stopPropagation();
  state.days[key] = !state.days[key];
  save(); renderPlan(); refreshOverview();
}

function isWeekDone(w) {
  return ['mon','tue','wed','thu','fri'].every(d => !!state.days[w+'-'+d]);
}

function doneCount() {
  return Object.values(state.days).filter(Boolean).length;
}

function refreshOverview() {
  const el = document.getElementById('days-done-count');
  if (el) el.textContent = doneCount();
}

function renderProgress() {
  const done = doneCount();
  const pct = Math.round((done / 60) * 100);
  document.getElementById('overall-bar').style.width = pct + '%';
  document.getElementById('progress-text').textContent = done + ' / 60 sessions complete';
  document.getElementById('progress-pct').textContent = pct + '%';
  Object.keys(state.metrics).forEach(k => {
    const el = document.getElementById(k);
    if (el) el.value = state.metrics[k];
  });
}

function saveMetric(k, v) { state.metrics[k] = v; save(); }

function renderChecklist() {
  const c = document.getElementById('checklist-container');
  c.innerHTML = '';
  CHECKLIST.forEach((item, i) => {
    const checked = !!state.checks[i];
    const div = document.createElement('div');
    div.className = 'checklist-item' + (checked ? ' checked' : '');
    div.onclick = () => { state.checks[i] = !state.checks[i]; save(); renderChecklist(); };
    div.innerHTML = `<div class="check-box">✓</div><div class="check-text">${item.t}<small>${item.d}</small></div>`;
    c.appendChild(div);
  });
}

function updateCountdown() {
  let rd = localStorage.getItem('hyrox_race');
  if (!rd) {
    const d = new Date(); d.setDate(d.getDate() + 84);
    rd = d.toISOString().split('T')[0];
    localStorage.setItem('hyrox_race', rd);
  }
  const diff = Math.ceil((new Date(rd) - new Date()) / 86400000);
  const badge = document.getElementById('countdown-badge');
  badge.textContent = diff > 0 ? diff + ' DAYS OUT' : diff === 0 ? 'RACE DAY 🏁' : 'POST RACE';
}

// init
renderPlan();
refreshOverview();
updateCountdown();
</script>
</body>
</html>
